menuconfig SAP
	bool "Secure Application Pairing (SAP)"
	depends on BT
	select MBEDTLS
	select MBEDTLS_PSA_CRYPTO_C
	select PSA_CRYPTO
	select PSA_WANT_GENERATE_RANDOM
	select PSA_WANT_ALG_SHA_256
	select PSA_WANT_ALG_ECDSA
	select PSA_WANT_ALG_ECDH
	select PSA_WANT_ALG_HKDF
	select PSA_WANT_ALG_HMAC
	select PSA_WANT_ALG_CCM
	select PSA_WANT_KEY_TYPE_AES
	select PSA_WANT_KEY_TYPE_DERIVE
	select PSA_WANT_KEY_TYPE_RAW_DATA
	select PSA_WANT_KEY_TYPE_ECC_PUBLIC_KEY
	select PSA_WANT_KEY_TYPE_ECC_KEY_PAIR_IMPORT
	select PSA_WANT_KEY_TYPE_ECC_KEY_PAIR_GENERATE
	select PSA_WANT_KEY_TYPE_ECC_KEY_PAIR_EXPORT
	select PSA_WANT_ECC_SECP_R1_256
	help
	  Enable the reusable Secure Application Pairing library. SAP adds
	  application-layer mutual authentication, per-connection session key
	  derivation, and AES-CCM protection for application payloads carried
	  over BLE.

if SAP

config SAP_MAX_PEERS
	int "Maximum SAP peers"
	range 1 8
	default 4
	help
	  Maximum number of concurrent SAP sessions stored in one sap_context.

config SAP_DEMO_LOGGING
	bool "Enable verbose SAP flow logging"
	default n
	help
	  Emit a step-by-step trace of the SAP handshake and post-auth state
	  transitions. This is intended for demos and walkthroughs.

config SAP_PACKET_LOGGING
	bool "Enable raw SAP packet logging"
	default n
	help
	  Emit hexdumps of the raw SAP auth packets and encrypted SAP secure
	  frames crossing the GATT transport. This is intended for protocol
	  debugging, not presentation use.

config SAP_LOG_LEVEL
	int "SAP module log level"
	default 4 if SAP_DEMO_LOGGING || SAP_PACKET_LOGGING
	default 3

endif

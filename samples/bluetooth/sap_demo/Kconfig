# Work around Kconfig's lack of commas in macro arguments.
DT_CHOSEN_Z_SHELL_UART := zephyr,shell-uart

mainmenu "Secure Application Pairing Demo"

source "Kconfig.zephyr"

menu "SAP demo configuration"

choice SAP_ROLE
	prompt "SAP role"
	default SAP_ROLE_CENTRAL

config SAP_ROLE_CENTRAL
	bool "Root node"
	select BT_CENTRAL
	select BT_OBSERVER
	select BT_GATT_CLIENT
	select BT_GATT_DM
	select BT_PERIPHERAL

config SAP_ROLE_PERIPHERAL
	bool "Leaf node"
	select BT_PERIPHERAL

endchoice

config SAP_EXPECTED_GROUP_ID
	hex "Expected SAP group identifier"
	default 0x2A

config SAP_ALLOWED_CENTRAL_ID
	int "Allowed central device identifier"
	range 0 255
	default 0

config SAP_UPSTREAM_ALLOWED_CENTRAL_ID
	int "Allowed upstream controller identifier"
	range 0 255
	default 42
	depends on SAP_ROLE_CENTRAL
	help
	  Device identifier that the root node accepts on its upstream SAP
	  controller link. The default is used by the Bleak host demo script.

config SAP_REQUIRE_BLE_ENCRYPTION
	bool "Require BLE link encryption before SAP"
	default n if BOARD_NRF54L15BSIM
	default y
	help
	  Keep BLE SMP/link encryption as a prerequisite for SAP when the target
	  supports it reliably. On the nrf54l15bsim sample target this defaults
	  to disabled because local BabbleSim validation could not complete the
	  BLE security procedure reliably on that simulator target. The sample
	  still exercises SAP mutual authentication and SAP-level AES-CCM
	  transport protection there.

config SAP_UPSTREAM_REQUIRE_BLE_ENCRYPTION
	bool "Require BLE link encryption on the root upstream controller link"
	depends on SAP_ROLE_CENTRAL
	default y
	help
	  Keep BLE SMP/link encryption as a prerequisite for the root node's
	  upstream SAP controller link. Disable this only for interop demos where
	  the external controller stack cannot complete BLE security reliably and
	  you still want to demonstrate SAP mutual authentication plus SAP-level
	  encrypted transport on that upstream link.

config SAP_USE_BLE_SC_OOB_PAIRING
	bool "Use in-band exchanged BLE Secure Connections OOB for post-auth transport"
	depends on BT_SMP
	default n
	help
	  Prototype a CBAP-like transport flow for root-to-leaf links. SAP still
	  performs certificate-based authentication, but the authenticated nodes
	  exchange LE Secure Connections OOB data during the SAP handshake, then
	  upgrade the BLE link to Security Level 4 and rely on the BLE stack for
	  transport encryption. SAP application payloads then travel as plaintext
	  over the authenticated encrypted BLE link instead of using SAP AES-CCM
	  on every packet. The root's upstream controller link remains on the
	  original SAP encrypted transport path.

config SAP_SHELL
	bool "Enable SAP shell commands"
	default y if !BOARD_NRF54L15BSIM
	default n if BOARD_NRF54L15BSIM
	select SHELL
	select SHELL_VT100_COLORS
	depends on $(dt_chosen_enabled,$(DT_CHOSEN_Z_SHELL_UART)) || BOARD_NRF54L15BSIM
	help
	  Enable a UART shell with SAP demo commands. The central build can list
	  peers and send secure text to one peer or all peers. The peripheral
	  build can send secure text to the connected central. Boards without a
	  non-secure ``zephyr,shell-uart`` chosen node leave the shell disabled
	  by default so the demo can still run without a UART.

if SAP_SHELL

config SHELL_STACK_SIZE
	default 8192

config SHELL_CMD_BUFF_SIZE
	default 256

config SHELL_ARGC_MAX
	default 16

config SHELL_BACKEND_SERIAL_TX_RING_BUFFER_SIZE
	default 1024

endif

config SAP_DK_IO
	bool "Enable DK button and LED demo IO"
	depends on BOARD_NRF54L15DK_NRF54L15_CPUAPP || \
		BOARD_NRF54L15DK_NRF54L15_CPUAPP_NS
	default y
	select DK_LIBRARY
	help
	  Enable the Nordic DK buttons and LEDs for the SAP demo. On the
	  peripheral, Button 1 sends a secure button-state event. On the
	  central, peripherals 1..4 map to LEDs 1..4. Additional peripherals
	  remain authenticated but do not receive an LED assignment.

config SAP_DEMO_PERIPHERAL_ID
	int "Hardware peripheral device identifier"
	depends on SAP_ROLE_PERIPHERAL && !BOARD_NRF54L15BSIM
	range 1 4
	default 1
	help
	  Select which demo peripheral credential this hardware build should use.
	  The sample contains four provisioned peripheral identities with device
	  IDs 1..4. Build each real peripheral with a different value so the
	  central can authenticate and track them as distinct SAP peers.

config SAP_DEMO_GATED_DFU_SERVICE
	bool "Expose gated MCUmgr DFU SMP service after SAP"
	default y if !BOARD_NRF54L15BSIM
	default n if BOARD_NRF54L15BSIM
	help
	  Demonstrate how SAP can hide the standard Bluetooth MCUmgr SMP/DFU
	  service until application-layer authentication succeeds. On hardware,
	  the central then verifies the service by sending an MCUmgr OS echo
	  request after SAP completes.

config SAP_DEMO_DFU_CLIENT
	bool
	default y if SAP_ROLE_CENTRAL && SAP_DEMO_GATED_DFU_SERVICE
	select BT_DFU_SMP
	select ZCBOR

config SAP_DEMO_DFU_SERVER
	bool
	default y if SAP_ROLE_PERIPHERAL && SAP_DEMO_GATED_DFU_SERVICE
	select CRC
	select IMG_MANAGER
	select MCUMGR
	select MCUMGR_GRP_IMG
	select MCUMGR_GRP_OS
	select MCUMGR_TRANSPORT_BT
	select MCUMGR_TRANSPORT_BT_DYNAMIC_SVC_REGISTRATION
	select NET_BUF
	select STREAM_FLASH
	select ZCBOR

config SAP_DEMO_LED_PATTERN_ID
	int "Leaf status LED pattern identifier"
	range 1 2
	default 1
	depends on SAP_ROLE_PERIPHERAL
	help
	  Distinguishes visible leaf firmware variants for the DFU demo. Pattern
	  1 is the default image. Pattern 2 is intended for the post-DFU image
	  so the result is obvious on-device.

endmenu
